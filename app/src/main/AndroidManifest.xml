<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SpeakUp">

        <activity
            android:name=".ui.view.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.view.LoginActivity" />
        <activity android:name=".ui.view.RegisterActivity" />
        <activity android:name=".ui.view.MainActivity" />
        <activity android:name=".ui.view.ReportActivity" />
        <activity android:name=".ui.view.ReportDetailActivity" />
        <activity android:name=".ui.view.EducationActivity" />
        <activity android:name=".ui.view.EducationDetailActivity" />
        <activity android:name=".ui.view.ChatActivity" />
        <activity android:name=".ui.view.EditProfileActivity" />

    </application>

</manifest>